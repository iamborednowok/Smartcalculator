<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        CRASH FIX: Use Theme.DeviceDefault.NoActionBar (no "Light" variant) so
        Android's pre-render window background is black, not white.
        Theme.DeviceDefault.Light sets windowBackground to white, which causes
        the visible white-screen flash while Qt's rendering engine is starting.
        windowBackground is explicitly set to black to match the app's Neon Noir
        dark theme and eliminate all white-screen artifacts on launch.
    -->
    <style name="AppTheme" parent="@android:style/Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
    </style>
</resources>
